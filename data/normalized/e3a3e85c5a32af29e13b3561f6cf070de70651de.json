  "novel_contributions": [
    "a simple network architecture, gMLP, based on MLPs with gating",
    "an MLP-based alternative to Transformers without self-attention",
    "the Spatial Gating Unit (SGU) for spatial interactions across tokens",
    "a tiny self-attention hybrid, aMLP, that improves finetuning on tasks requiring cross-sentence alignment",
    "evidence that gMLP can scale as well as Transformers over increased data and compute"
  ],
  "key_claims": [
    {
      "claim": "gMLP can perform as well as Transformers in key language and vision applications, despite removing self-attention.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "For Vision Transformers, self-attention is not critical because gMLP can achieve the same accuracy.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "gMLP achieves parity with Transformers on BERT pretraining perplexity and is better on some downstream NLP tasks.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "A large gMLP model achieves 87.7% accuracy on MNLI and 82.1% F1 on SQuAD v2.0 with a standard 256-batch size × 1M-step training setup.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "A tiny single-head self-attention with size up to 128 is sufficient to make gMLPs outperform Transformers on all NLP tasks evaluated.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "All ImageNet models are trained using TPUv2 with 128 cores and each run takes 1-4 hours to complete.",
      "evidence_section": "A.1 Image Classification",
      "page": null
    },
    {
      "claim": "For MLM pretraining, models in the full BERT setup are trained using TPUv2 with 128 cores and each run takes 1-5 days to complete.",
      "evidence_section": "A.2 Masked Language Modeling",
      "page": null
    }
  ]
}