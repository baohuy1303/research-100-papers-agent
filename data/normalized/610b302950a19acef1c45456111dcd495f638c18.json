  "novel_contributions": [
    "gated positional self-attention (GPSA), a self-attention layer that can be initialized as a convolutional layer and then learn to escape locality",
    "ConViT, a Vision Transformer variant that replaces early self-attention layers with GPSA layers",
    "an adaptive attention span design that keeps relative positional encodings fixed and trains only the positional embeddings",
    "an analysis of locality in vanilla self-attention and how GPSA layers evolve away from convolutional initialization",
    "evidence that soft inductive biases improve sample efficiency and can complement distillation"
  ],
  "key_claims": [
    {
      "claim": "ConViT outperforms the DeiT on ImageNet while offering much improved sample efficiency.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The paper introduces gated positional self-attention (GPSA), which can be initialized to mimic convolutional locality and then learn to escape it via a gating parameter.",
      "evidence_section": "Abstract / 3. Approach",
      "page": null
    },
    {
      "claim": "ConViT-S reaches 81.3 Top-1 on ImageNet-1k, and ConViT-B+ reaches 82.5 Top-1 in the main comparison table.",
      "evidence_section": "3. Approach / Table 1",
      "page": null
    },
    {
      "claim": "On subsampled ImageNet-1k, ConViT-S achieves substantially higher Top-1 and Top-5 accuracy than DeiT-S across all training fractions.",
      "evidence_section": "3. Approach / Table 2",
      "page": null
    },
    {
      "claim": "Hard distillation improves ConViT-S+ to 82.9 Top-1 on ImageNet, showing compatibility between soft inductive biases and distillation.",
      "evidence_section": "B. The effect of distillation / Table 4",
      "page": null
    },
    {
      "claim": "The gating parameter decreases during training in later layers, indicating that GPSA layers progressively rely less on positional information.",
      "evidence_section": "4. Investigating the role of locality",
      "page": null
    },
    {
      "claim": "The convolutional initialization is especially beneficial in the low-data regime and during early training.",
      "evidence_section": "4. Investigating the role of locality / Figure 8",
      "page": null
    },
    {
      "claim": "Masking positional embeddings has a much smaller effect on ConViT-Ti than on DeiT-Ti.",
      "evidence_section": "F. Further ablations / Table 5",
      "page": null
    }
  ]
