  "novel_contributions": [
    "a dynamic token sparsification framework to prune redundant tokens progressively and dynamically based on the input",
    "a lightweight prediction module to estimate token importance scores and prune tokens hierarchically",
    "an attention masking strategy to differentially prune tokens while keeping training parallelizable",
    "an end-to-end optimization method using Gumbel-Softmax for token pruning",
    "competitive complexity/accuracy trade-offs on ImageNet with 66% token pruning, 31% ~ 37% FLOPs reduction, and over 40% throughput improvement"
  ],
  "key_claims": [
    {
      "claim": "By hierarchically pruning 66% of the input tokens, DynamicViT reduces 31% ~ 37% FLOPs and improves throughput by over 40% while keeping the accuracy drop within 0.5% for various vision transformers.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "DynamicViT uses a lightweight prediction module added to multiple layers to dynamically decide which tokens to prune based on the current features.",
      "evidence_section": "Abstract / 3.2 Hierarchical Token Sparsification with Prediction Modules",
      "page": null
    },
    {
      "claim": "Attention masking is introduced so token pruning can be trained end-to-end without changing the attention tensor shape during training.",
      "evidence_section": "3.3 End-to-end Optimization with Attention Masking",
      "page": null
    },
    {
      "claim": "The model is trained with Gumbel-Softmax, distillation loss, KL loss, and ratio loss to jointly optimize pruning decisions and backbone adaptation.",
      "evidence_section": "3.3 End-to-end Optimization with Attention Masking / 3.4 Training and Inference",
      "page": null
    },
    {
      "claim": "On ImageNet, DynamicViT achieves strong speed-accuracy trade-offs on DeiT-S, LV-ViT-S, and LV-ViT-M backbones.",
      "evidence_section": "4.1 Main results",
      "page": null
    },
    {
      "claim": "Dynamic sparsification outperforms structural downsampling, static sparsification, random removal, and attention-based token removal in the ablation study.",
      "evidence_section": "B More Analysis / Comparisons of different sparsification strategies",
      "page": null
    },
    {
      "claim": "DynamicViT also scales to larger models and larger input sizes, reducing GFLOPs substantially with small accuracy drops.",
      "evidence_section": "4.3 Analysis / Accelerating larger models",
      "page": null
    }
  ]
}