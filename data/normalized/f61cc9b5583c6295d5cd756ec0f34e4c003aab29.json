  "key_claims": [
    {
      "claim": "Qwen2.5-VL introduces dynamic resolution processing and absolute time encoding, enabling it to process images of varying sizes and videos of extended durations (up to hours) with second-level event localization.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The model trains a native dynamic-resolution Vision Transformer from scratch and incorporates Window Attention to reduce computational overhead while maintaining native resolution.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "Qwen2.5-VL is available in three sizes, and the flagship Qwen2.5-VL-72B matches state-of-the-art models like GPT-4o and Claude 3.5 Sonnet, particularly in document and diagram understanding.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The paper’s four technical contributions are window attention in the visual encoder, dynamic FPS sampling, absolute-time-aligned MRoPE, and large-scale data curation for pre-training and supervised fine-tuning.",
      "evidence_section": "1 Introduction",
      "page": null
    },
    {
      "claim": "The pre-training corpus is expanded from 1.2 trillion tokens to 4.1 trillion tokens.",
      "evidence_section": "1 Introduction",
      "page": null
    },
    {
      "claim": "Qwen2.5-VL-72B achieves 70.2 on MMMU dev, 74.8 on MathVista mini, and 88.6 on MMBench-EN test in Table 3.",
      "evidence_section": "3.1 Comparison with the SOTA Models",
      "page": null
    },
    {
      "claim": "Qwen2.5-VL-72B sets new state-of-the-art results on several OCR/document benchmarks including CC-OCR, OmniDocBench, DocVQA, InfoVQA, OCRBench, and OCRBench_v2.",
      "evidence_section": "3.3.2 Document Understanding and OCR",
      "page": null
    },
    {
      "claim": "Qwen2.5-VL-72B achieves strong video understanding and grounding results, including 50.9 mIoU on Charades-STA and leading scores on MVBench, LVBench, EgoSchema, MLVU, TempCompass, and GUI agent benchmarks.",
      "evidence_section": "3.3.4 Video Understanding and Grounding",
      "page": null
    }
  ]
