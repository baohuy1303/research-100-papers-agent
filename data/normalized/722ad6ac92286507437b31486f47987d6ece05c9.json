  "novel_contributions": [
    "We propose a masked image modeling task to pretrain vision Transformers in a self-supervised manner.",
    "We also provide a theoretical explanation from the perspective of downstream autoencoder.",
    "We pretrain BEiT and conduct extensive fine-tuning experiments on downstream tasks, such as image classification, and semantic segmentation.",
    "We present that the self-attention mechanism of self-supervised BEiT learns to distinguish semantic regions and object boundaries, although without using any human annotation."
  ],
  "key_claims": [
    {
      "claim": "BEiT introduces masked image modeling for vision Transformers, predicting discrete visual tokens rather than raw pixels during self-supervised pre-training.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "BEiT outperforms from-scratch training and previous strong self-supervised models on image classification and semantic segmentation, and is complementary to supervised pre-training.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The model can learn reasonable semantic regions via self-supervised pre-training, as shown by self-attention visualizations.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "BEiT-B reaches 83.2 top-1 accuracy on ImageNet-1K, and BEiT 384-L reaches 86.3 in Table 1.",
      "evidence_section": "3.1 Image Classification",
      "page": null
    },
    {
      "claim": "BEiT-L + on In-House-70M reaches 89.5 top-1 accuracy on ImageNet-1K, and BEiT-L + reaches 58.4 Multi-Scale mIoU on ADE20K.",
      "evidence_section": "B Comparison with Large-Scale Supervised Pre-Training",
      "page": null
    },
    {
      "claim": "BEiT achieves 45.6 on ADE20K and improves to 47.7 with intermediate fine-tuning.",
      "evidence_section": "3.2 Semantic Segmentation",
      "page": null
    },
    {
      "claim": "Blockwise masking, discrete visual tokens, and longer pre-training are all shown by ablation to matter for downstream performance.",
      "evidence_section": "3.3 Ablation Studies",
      "page": null
    },
    {
      "claim": "BEiT fine-tuning converges faster than training DeiT from scratch on ImageNet-1K.",
      "evidence_section": "3.1 Image Classification",
      "page": null
    }
  ]
