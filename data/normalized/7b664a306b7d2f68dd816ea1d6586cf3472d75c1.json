  "novel_contributions": [
    "We conjecture that ViT’s substandard optimizability is primarily caused by the patchify stem.",
    "We introduce a minimal convolutional stem replacement for ViT that keeps flops and runtime roughly matched by removing one transformer block.",
    "We show that the convolutional stem dramatically increases optimization stability and improves peak performance by ~1-2% top-1 accuracy on ImageNet-1k.",
    "We show that the improvement holds across model complexities from 1G to 36G flops and dataset scales from ImageNet-1k to ImageNet-21k.",
    "We recommend using a standard, lightweight convolutional stem for ViT models in this regime as a more robust architectural choice."
  ],
  "key_claims": [
    {
      "claim": "Replacing ViT’s patchify stem with a lightweight convolutional stem makes optimization much more stable, faster, and less sensitive to learning rate and weight decay.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The convolutional stem improves peak ImageNet top-1 accuracy by ~1-2% while maintaining flops and runtime.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The improvement is observed across model complexities from 1G to 36G flops and dataset scales from ImageNet-1k to ImageNet-21k.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "ViT_C enables the use of either AdamW or SGD without a significant accuracy drop, unlike ViT_P.",
      "evidence_section": "Figure 1",
      "page": null
    },
    {
      "claim": "ViT_C converges faster than ViT_P on ImageNet-1k across 50 to 400 epoch schedules.",
      "evidence_section": "5.1 Training Length Stability",
      "page": null
    },
    {
      "claim": "ViT_C substantially reduces the optimizer gap between AdamW and SGD compared with ViT_P.",
      "evidence_section": "5.2 Optimizer Stability",
      "page": null
    },
    {
      "claim": "ViT_C improves learning rate and weight decay stability over ViT_P and matches or exceeds RegNetY in the EDF analysis.",
      "evidence_section": "5.3 Learning Rate and Weight Decay Stability",
      "page": null
    },
    {
      "claim": "Under the controlled peak-performance comparison, ViT_C outperforms state-of-the-art CNNs, while ViT_P does not.",
      "evidence_section": "6 Peak Performance",
      "page": null
    }
  ]
