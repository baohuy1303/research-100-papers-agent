  "novel_contributions": [
    "a pure-transformer backbone architecture for video recognition that is based on spatiotemporal locality inductive bias",
    "a spatiotemporal adaptation of Swin Transformer that extends local attention from the spatial domain to the spatiotemporal domain",
    "a 3D shifted window mechanism for video input",
    "an initialization strategy that leverages pre-trained image models, including ImageNet-21K pre-training"
  ],
  "key_claims": [
    {
      "claim": "The proposed Video Swin Transformer achieves state-of-the-art accuracy on Kinetics-400, Kinetics-600 and Something-Something v2.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The model reaches 84.9 top-1 accuracy on Kinetics-400 and 86.1 top-1 accuracy on Kinetics-600 with about 20× less pre-training data and about 3× smaller model size than previous approaches.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The approach obtains 69.6 top-1 accuracy on Something-Something v2, improving over previous state-of-the-art by +0.9 points.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "Video Swin Transformer uses locality in spatiotemporal self-attention to improve the speed-accuracy trade-off compared to global self-attention video Transformers.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The architecture is a hierarchical four-stage Swin-style backbone with 3D shifted windows and 3D relative position bias.",
      "evidence_section": "3 Video Swin Transformer",
      "page": null
    },
    {
      "claim": "For Kinetics-400 and Kinetics-600, the paper uses AdamW for 30 epochs with batch size 64 and a smaller backbone learning rate than the head.",
      "evidence_section": "4.1 Setup",
      "page": null
    },
    {
      "claim": "For Something-Something v2, the paper uses longer training of 60 epochs and stronger augmentation including label smoothing, RandAugment, and random erasing.",
      "evidence_section": "4.1 Setup",
      "page": null
    }
  ]
}