  "novel_contributions": [
    "A systematic empirical study of training self-supervised Vision Transformers.",
    "A MoCo v3 framework adapted for self-supervised ViT training with a simplified large-batch contrastive setup.",
    "An empirical finding that instability is a major issue in self-supervised ViT training and can cause hidden 1~3% accuracy degradation.",
    "A simple fixed random patch projection trick that improves stability and accuracy across MoCo v3, SimCLR, BYOL, and SwAV.",
    "Benchmarking and ablations of self-supervised ViT across multiple frameworks, architectures, and downstream transfer tasks."
  ],
  "key_claims": [
    {
      "claim": "Instability is a major issue in self-supervised ViT training, and it can cause mild but hidden accuracy degradation rather than catastrophic divergence.",
      "evidence_section": "Abstract; 4. Stability of Self-Supervised ViT Training",
      "page": null
    },
    {
      "claim": "Freezing the patch projection layer as a fixed random patch projection alleviates instability and consistently increases accuracy.",
      "evidence_section": "4.2. A Trick for Improving Stability",
      "page": null
    },
    {
      "claim": "MoCo v3 performs better than SimCLR, BYOL, and SwAV for ViT in ImageNet linear probing, with ViT-B reaching 76.5.",
      "evidence_section": "6.1. Self-supervised Learning Frameworks",
      "page": null
    },
    {
      "claim": "MoCo v3 achieves 83.2% with ViT-B and 84.1% with ViT-L under end-to-end fine-tuning on ImageNet-1k.",
      "evidence_section": "6.3. Comparisons with Prior Art",
      "page": null
    },
    {
      "claim": "Self-supervised ViT transfer learning improves from ViT-B to ViT-L and is better than ImageNet-supervised counterparts on three of four downstream datasets.",
      "evidence_section": "6.4. Transfer Learning",
      "page": null
    },
    {
      "claim": "Removing position embedding only slightly hurts performance, indicating that self-supervised ViT can learn strong representations without positional inductive bias.",
      "evidence_section": "6.2. Ablations of ViT + MoCo v3",
      "page": null
    },
    {
      "claim": "The paper finds that bigger self-supervised ViT models can improve accuracy, unlike the supervised ViT trend reported in prior work.",
      "evidence_section": "Abstract; 6.3. Comparisons with Prior Art",
      "page": null
    }
  ]
}