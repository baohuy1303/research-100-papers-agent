  "novel_contributions": [
    "an architectural modification to DeiT to encode shape-information via a dedicated token",
    "a shape distillation approach that distills shape knowledge from a pretrained CNN model with high shape-bias",
    "an off-the-shelf feature transfer approach that ensembles representations derived from a single architecture to obtain state-of-the-art generalization",
    "an extensive empirical study of robustness, shape-vs-texture bias, positional encoding, and transferability across fifteen vision datasets"
  ],
  "key_claims": [
    {
      "claim": "ViTs are highly robust to severe occlusions, perturbations and domain shifts, retaining as high as 60% top-1 accuracy on ImageNet even after randomly occluding 80% of the image content.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "ViTs are significantly less biased towards local textures than CNNs, and when properly trained to encode shape-based features they demonstrate shape recognition capability comparable to humans.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "Using ViTs to encode shape representation leads to accurate semantic segmentation without pixel-level supervision.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "Off-the-shelf features from a single ViT model can be combined into a feature ensemble, leading to high accuracy across classification datasets in traditional and few-shot learning settings.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The paper proposes a shape token in DeiT and shows that distinct tokens can model shape and texture cues within the same architecture.",
      "evidence_section": "3.2 Shape vs. Texture: Can Transformer Model Both Characteristics?",
      "page": null
    },
    {
      "claim": "The paper finds that positional encoding is not absolutely crucial for correct classification decisions under patch shuffling, and attributes ViT permutation robustness to dynamic receptive fields.",
      "evidence_section": "3.3 Does Positional Encoding Preserve the Global Image Context?",
      "page": null
    },
    {
      "claim": "The paper shows that ViT features transfer better than CNN features across several downstream datasets, and that the proposed ensemble strategy achieves the best results.",
      "evidence_section": "3.5 Effective Off-the-shelf Tokens for Vision Transformer",
      "page": null
    }
  ]
}