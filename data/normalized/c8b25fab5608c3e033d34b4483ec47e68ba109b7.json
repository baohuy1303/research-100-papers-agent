  "novel_contributions": [
    "We propose a hierarchical Transformer whose representation is computed with Shifted windows.",
    "The shifted windowing scheme brings greater efficiency by limiting self-attention computation to non-overlapping local windows while also allowing for cross-window connection.",
    "The hierarchical architecture has linear computational complexity with respect to image size.",
    "The hierarchical design and the shifted window approach also prove beneficial for all-MLP architectures."
  ],
  "key_claims": [
    {
      "claim": "Swin Transformer is a general-purpose backbone for computer vision with hierarchical feature maps and linear computational complexity with respect to image size.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The model achieves 87.3 top-1 accuracy on ImageNet-1K, 58.7 box AP and 51.1 mask AP on COCO test-dev, and 53.5 mIoU on ADE20K val.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "Its performance surpasses the previous state-of-the-art by +2.7 box AP and +2.6 mask AP on COCO, and +3.2 mIoU on ADE20K.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "Shifted windows provide cross-window connections and are more efficient than sliding-window self-attention while maintaining similar modeling power.",
      "evidence_section": "3.2. Shifted Window based Self-Attention",
      "page": null
    },
    {
      "claim": "Relative position bias improves performance, while absolute position embedding slightly hurts dense prediction tasks.",
      "evidence_section": "3.2. Shifted Window based Self-Attention",
      "page": null
    },
    {
      "claim": "Swin-T with shifted windows outperforms the non-shifted variant by +1.1% top-1 on ImageNet-1K, +2.8 box AP/+2.2 mask AP on COCO, and +2.8 mIoU on ADE20K.",
      "evidence_section": "4.4. Ablation Study",
      "page": null
    },
    {
      "claim": "Swin-L (HTC++)* achieves 58.7 box AP and 51.1 mask AP on COCO test-dev, surpassing Copy-paste and DetectoRS.",
      "evidence_section": "4.2. Object Detection on COCO",
      "page": null
    },
    {
      "claim": "Swin-L with ImageNet-22K pre-training achieves 53.5 mIoU on ADE20K val, surpassing the previous best model by +3.2 mIoU.",
      "evidence_section": "4.3. Semantic Segmentation on ADE20K",
      "page": null
    }
  ]
