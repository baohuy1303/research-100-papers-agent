  "novel_contributions": [
    "develop Grounding DINO, an open-set object detector, by marrying Transformer-based detector DINO with grounded pre-training",
    "propose a tight fusion solution that includes a feature enhancer, a language-guided query selection, and a cross-modality decoder",
    "introduce sub-sentence level text features to remove attention between unrelated categories during word feature extractions",
    "pre-train on large-scale datasets including object detection data, grounding data, and caption data",
    "extend evaluation to open-set object detection and referring object detection benchmarks"
  ],
  "key_claims": [
