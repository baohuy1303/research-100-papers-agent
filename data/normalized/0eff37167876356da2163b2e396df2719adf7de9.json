  "novel_contributions": [
    "A novel dual-branch vision transformer to extract multi-scale feature representations for image classification.",
    "A simple yet effective token fusion scheme based on cross-attention, which is linear in both computation and memory.",
    "The model performs better than or on par with several concurrent works based on ViT, and demonstrates comparable results with EfficientNet with regards to accuracy, throughput and model parameters."
  ],
  "key_claims": [
    {
      "claim": "CrossViT proposes a dual-branch vision transformer that combines small-patch and large-patch tokens to learn multi-scale feature representations for image classification.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The proposed cross-attention fusion uses CLS tokens as queries and is linear in both computational and memory complexity instead of quadratic time.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "On ImageNet1K, CrossViT outperforms DeiT by a large margin of 2% with a small to moderate increase in FLOPs and model parameters.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "CrossViT-18† achieves 82.8 on ImageNet1K and is described as performing as well as TNT-B while using fewer FLOPs and parameters.",
      "evidence_section": "4.2. Main Results",
      "page": null
    },
    {
      "claim": "CrossViT-15† is competitive with EfficientNet on ImageNet1K in accuracy, throughput and parameters at higher resolution.",
      "evidence_section": "4.2. Main Results",
      "page": null
    },
    {
      "claim": "Cross-attention fusion achieves the best accuracy among the compared fusion schemes on ImageNet1K.",
      "evidence_section": "4.3. Ablation Studies",
      "page": null
    },
    {
      "claim": "The model is trained on ImageNet1K from scratch for 300 epochs with batch size 4,096 using RandAugment, mixup, CutMix, random erasing, and drop path.",
      "evidence_section": "4.1. Experimental Setup",
      "page": null
    }
  ]
