  "novel_contributions": [
    "We introduce VGGT, a large feed-forward transformer that predicts all key 3D attributes of a scene from one, a few, or even hundreds of images in seconds.",
    "We demonstrate that a fairly standard transformer with minimal 3D inductive biases can outperform optimization-based alternatives without further processing.",
    "We show that jointly predicting cameras, depth maps, point maps, and tracking features improves performance, and that VGGT features transfer well to downstream tasks such as novel view synthesis and dynamic point tracking.",
    "We show that combining VGGT with BA post-processing yields state-of-the-art results across multiple 3D tasks."
  ],
  "key_claims": [
    {
      "claim": "VGGT directly infers camera parameters, point maps, depth maps, and 3D point tracks from one, a few, or hundreds of views in a single forward pass.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The model is simple and efficient, reconstructing images in under one second and often outperforming alternatives that require post-processing with visual geometry optimization techniques.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "VGGT achieves state-of-the-art results in multiple 3D tasks, including camera parameter estimation, multi-view depth estimation, dense point cloud reconstruction, and 3D point tracking.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "VGGT uses a standard large transformer with alternating frame-wise and global self-attention and minimal 3D inductive biases.",
      "evidence_section": "1. Introduction / 3.2. Feature Backbone",
