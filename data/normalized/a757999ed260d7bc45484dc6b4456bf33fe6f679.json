  "key_claims": [
    {
      "claim": "LLaMA-Adapter introduces only 1.2M learnable parameters on top of frozen LLaMA 7B and costs less than one hour for fine-tuning.",
      "evidence_section": "ABSTRACT",
      "page": null
    },
    {
      "claim": "The proposed zero-initialized attention mechanism stabilizes training by progressively injecting instructional cues while preserving pre-trained knowledge.",
      "evidence_section": "3.2 ZERO-INITIALIZED ATTENTION",
      "page": null
    },
    {
      "claim": "LLaMA-Adapter can be extended to a Multi-modal LLM and achieves superior multi-modal reasoning capacity on MME, MMBench, and LVLM-eHub.",
      "evidence_section": "ABSTRACT",
      "page": null
    },
    {
      "claim": "On ScienceQA, LLaMA-Adapter improves from 78.31% for LLaMA-Adapter_T to 85.19% for the multi-modal model.",
      "evidence_section": "4.2 MULTI-MODAL EVALUATION",
      "page": null
    },
    {
      "claim": "The method generalizes to traditional vision, language, and vision-language fine-tuning, outperforming or matching strong baselines on VTAB-1k, SQuAD, and base-to-novel CLIP evaluation.",
      "evidence_section": "4.4 ZERO-INITIALIZED ATTENTION FOR OTHER LARGE MODELS",
      "page": null
    },
    {
      "claim": "LLaMA-Adapter achieves better average performance than Alpaca and Alpaca-LoRA on the Open LLM benchmark.",
      "evidence_section": "E.4 MORE QUANTITATIVE COMPARISON WITH ALPACA-LoRA",
      "page": null
    }
  ]
