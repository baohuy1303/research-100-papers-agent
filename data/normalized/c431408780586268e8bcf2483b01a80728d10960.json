  "novel_contributions": [
    "A pre-training-free adapter for plain ViT that injects image-related inductive biases for dense prediction tasks.",
    "A spatial prior module plus spatial feature injector and multi-scale feature extractor to adapt ViT without modifying its original architecture.",
    "A new paradigm that preserves ViT flexibility and can benefit from multi-modal pre-training.",
    "State-of-the-art results on COCO test-dev without extra detection data and strong results on ADE20K."
  ],
  "key_claims": [
    {
      "claim": "ViT-Adapter is a pre-training-free adapter that lets plain ViT achieve comparable performance to vision-specific transformers on dense prediction tasks.",
      "evidence_section": "ABSTRACT",
      "page": null
    },
    {
      "claim": "The method uses three tailored modules: a spatial prior module, a spatial feature injector, and a multi-scale feature extractor.",
      "evidence_section": "1 INTRODUCTION",
      "page": null
    },
    {
      "claim": "With only ImageNet-1K pre-training, ViT-Adapter-B reports 49.6 box AP on COCO val and outperforms Swin-B by 1.0 points.",
      "evidence_section": "1 INTRODUCTION",
      "page": null
    },
    {
      "claim": "ViT-Adapter-L yields state-of-the-art 60.9 box AP and 53.0 mask AP on COCO test-dev without extra detection data.",
      "evidence_section": "ABSTRACT",
      "page": null
    },
    {
      "claim": "On ADE20K, ViT-Adapter-L reaches 61.5 mIoU and is reported as a new record in the comparison table.",
      "evidence_section": "4.3 COMPARISONS WITH STATE-OF-THE-ARTS",
      "page": null
    },
    {
      "claim": "The adapter can benefit from advanced multi-modal pre-training, improving results over ImageNet-22K pre-training.",
      "evidence_section": "4.1 OBJECT DETECTION AND INSTANCE SEGMENTATION",
      "page": null
    },
    {
      "claim": "Ablations show the proposed components collectively bring 4.5 APb and 2.8 APm gains, and the best number of interactions is N = 4.",
      "evidence_section": "4.4 ABLATION STUDY",
      "page": null
    }
  ]
