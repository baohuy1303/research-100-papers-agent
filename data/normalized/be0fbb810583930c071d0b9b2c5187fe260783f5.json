  "novel_contributions": [
    "a residual-post-norm method combined with cosine attention to improve training stability",
    "A log-spaced continuous position bias method to effectively transfer models pre-trained using low-resolution images to downstream tasks with high-resolution inputs",
    "A self-supervised pre-training method, SimMIM, to reduce the needs of vast labeled images",
    "trained a 3 billion-parameter Swin Transformer V2 model, which is the largest dense vision model to date",
    "makes it capable of training with images of up to 1,536×1,536 resolution"
  ],
  "key_claims": [
    {
      "claim": "The paper proposes residual-post-norm, scaled cosine attention, and log-spaced continuous position bias to address training instability and resolution-transfer issues in large vision models.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "Swin Transformer V2 can be scaled to a 3 billion-parameter model and trained with images of up to 1,536×1,536 resolution.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "Using SimMIM self-supervised pre-training reduces the dependence on labeled data, and the paper reports using 40 times less labelled data than JFT-3B.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The 3B model sets new performance records on ImageNet-V2, COCO, ADE20K, and Kinetics-400.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "Log-spaced CPB transfers better than parameterized position bias and linear-spaced CPB when moving from low-resolution pre-training to higher-resolution fine-tuning.",
      "evidence_section": "3.3. Scaling Up Window Resolution",
      "page": null
    },
    {
      "claim": "Residual post normalization and scaled cosine attention improve stability and accuracy, especially for larger models.",
      "evidence_section": "3.2. Scaling Up Model Capacity",
      "page": null
    },
    {
      "claim": "The largest model uses ZeRO, activation check-pointing, and sequential self-attention computation to reduce GPU memory consumption.",
      "evidence_section": "3.5. Implementation to Save GPU Memory",
      "page": null
    }
  ]
