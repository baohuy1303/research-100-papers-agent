  "novel_contributions": [
    "ALBEF, a new VLP framework that aligns image and text representations before fusion",
    "Momentum Distillation (MoD), a self-training method that learns from pseudo-targets produced by a momentum model",
    "A theoretical mutual-information maximization perspective for ITC, MLM, and MoD",
    "A detector-free vision-language pre-training approach that does not require bounding box annotations nor high-resolution images"
  ],
  "key_claims": [
    {
      "claim": "ALBEF aligns image and text representations before fusing them through cross-modal attention, enabling more grounded vision-language representation learning.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The method does not require bounding box annotations nor high-resolution images.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "Momentum distillation is proposed to improve learning from noisy web data by using pseudo-targets from a momentum model.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "ALBEF achieves state-of-the-art performance on multiple downstream vision-language tasks.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "On VQA and NLVR2, ALBEF achieves absolute improvements of 2.37% and 3.84% compared to the state-of-the-art.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "ALBEF outperforms methods pre-trained on orders of magnitude larger datasets on image-text retrieval.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "With 14M pre-training images, ALBEF achieves 98.70 TR, 94.07 IR, 80.91 on SNLI-VE test, 83.14 on NLVR2 test-P, and 75.84 on VQA test-dev in Table 1.",
      "evidence_section": "6.1 Evaluation on the Proposed Methods",
      "page": null
    }
  ]
