  "novel_contributions": [
    "We explore the plain, non-hierarchical Vision Transformer (ViT) as a backbone network for object detection.",
    "We build a simple feature pyramid from only the last feature map of a plain ViT backbone, without the common FPN design.",
    "We use non-overlapping window attention without shifting, aided with very few cross-window propagation blocks.",
    "ViTDet can compete with previous leading hierarchical-backbone methods, reaching up to 61.3 AP^box on COCO using only ImageNet-1K pre-training.",
    "The paper demonstrates competitive results on the long-tailed LVIS detection dataset."
  ],
  "key_claims": [
    {
      "claim": "A plain, non-hierarchical ViT backbone can be adapted for object detection with minimal changes during fine-tuning, without redesigning pre-training.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "A simple feature pyramid built from a single-scale feature map is sufficient, and the common FPN design is not necessary for a plain ViT backbone.",
      "evidence_section": "Abstract; 3 Method",
      "page": null
    },
    {
      "claim": "Window attention without shifting works well when information is propagated across windows by only a few cross-window blocks.",
      "evidence_section": "Abstract; 3 Method",
      "page": null
    },
    {
      "claim": "With MAE pre-training on ImageNet-1K, ViTDet can compete with leading hierarchical-backbone detectors and reaches up to 61.3 AP^box on COCO.",
      "evidence_section": "Abstract; 4.3 Comparisons with Previous Systems",
      "page": null
    },
    {
      "claim": "ViTDet shows competitive results on LVIS as well, despite the long-tailed distribution.",
      "evidence_section": "Abstract; 4.3 Comparisons with Previous Systems",
      "page": null
    },
    {
      "claim": "MAE pre-training on IN-1K gives large gains over supervised pre-training for plain ViT backbones on COCO.",
      "evidence_section": "4 Experiments",
      "page": null
    }
  ]
