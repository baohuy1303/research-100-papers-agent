  "novel_contributions": [
    "We propose a simple yet effective framework, namely AdaptFormer, for adapting vision transformers to a large variety of downstream visual recognition tasks and avoiding catastrophic interference with each other.",
    "This is the first work that explores efficient fine-tuning in video action recognition.",
    "AdaptFormer introduces lightweight modules that only add less than 2% extra parameters to a ViT while keeping the original pre-trained parameters frozen.",
    "AdaptFormer is plug-and-play in different Transformers and scalable to many visual tasks.",
    "Extensive experiments on five image and video datasets show that AdaptFormer largely improves ViTs in the target domains."
  ],
  "key_claims": [
    {
      "claim": "AdaptFormer introduces lightweight modules that add less than 2% extra parameters to a ViT and can increase transferability without updating the original pre-trained parameters.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "AdaptFormer significantly outperforms existing 100% fully fine-tuned models on action recognition benchmarks.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "With just 1.5% extra parameters, AdaptFormer achieves about 10% and 19% relative improvement compared to fully fine-tuned models on Something-Something v2 and HMDB51, respectively.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "AdaptFormer-64 outperforms VPT on CIFAR-100, SVHN, and Food-101, and also improves over full-tuning on Something-Something V2 in the self-supervised setting.",
      "evidence_section": "4.2 Main Properties and Analysis",
      "page": null
    },
    {
      "claim": "AdaptFormer remains stable as tunable parameters scale up, unlike VPT which degrades sharply when the number of tokens becomes too large.",
      "evidence_section": "4.3 Scaling Tunable Parameters Up",
