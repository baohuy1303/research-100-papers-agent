  "novel_contributions": [
    "This survey provides a comprehensive overview of Transformer models in the computer vision discipline.",
    "It develops a taxonomy of the network design space and organizes recent approaches according to the intrinsic features of self-attention and the investigated task.",
    "It compares the respective advantages and limitations of popular techniques both in terms of architectural design and their experimental value.",
    "It analyzes open research directions and possible future works for Transformer models in computer vision."
  ],
  "key_claims": [
    {
      "claim": "The survey provides a comprehensive overview of Transformer models in computer vision and covers applications from recognition and detection to generation, multi-modal tasks, video processing, low-level vision, and 3D analysis.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "Transformers enable modeling long dependencies, parallel sequence processing, minimal inductive biases, and scalability to very large capacity networks and huge datasets.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The paper organizes vision Transformers into single-head self-attention and multi-head self-attention families, and further categorizes multi-head designs into uniform-scale, multi-scale, hybrid, and self-supervised ViTs.",
      "evidence_section": "3 SELF-ATTENTION & TRANSFORMERS IN VISION",
      "page": null
    },
    {
      "claim": "The survey states that recent approaches show convolution operations can be fully replaced with attention-based transformer modules and can also be used jointly with convolution in hybrid designs.",
      "evidence_section": "Introduction",
      "page": null
    },
    {
      "claim": "The paper highlights that self-supervised pre-training is crucial for Transformer scalability and generalization, enabling training even above a trillion parameter networks.",
      "evidence_section": "2.2 (Self) Supervised Pre-training",
      "page": null
    },
    {
      "claim": "The survey emphasizes that Transformer models often require large-scale data and high computational cost, motivating efficient designs such as sparse attention, linear attention, and other approximations.",
      "evidence_section": "4.1 High Computational Cost",
      "page": null
    },
    {
      "claim": "The paper reports that CLIP achieves 75% zero-shot classification accuracy on ImageNet and demonstrates zero-shot transfer on 30 different computer vision benchmarks.",
      "evidence_section": "3.7.1 Multi-stream Transformers",
      "page": null
    },
    {
      "claim": "The paper states that METRO obtains state-of-the-art results on human mesh reconstruction on Human3.6M and 3DPW.",
      "evidence_section": "3.11 Transformers for 3D Analysis",
      "page": null
    }
  ]
}