  "novel_contributions": [
    "This is the first survey paper that comprehensively covers applications of Transformers in the medical imaging domain, thereby bridging the gap between the vision and medical imaging community in this rapidly evolving area.",
    "We provide a detailed coverage of the field by categorizing the papers based on their applications in medical imaging, and for each application we develop a taxonomy, highlight task-specific challenges, and provide insights about solving them based on the literature reviewed.",
    "We provide a critical discussion of the field’s current state as a whole, including identifying key challenges, highlighting open problems, and outlining promising future directions.",
    "We are also the first since the inception of the original Transformer, about half a decade ago, to extensively cover its language modeling capabilities in the clinical report generation task.",
    "We intend to regularly update the relevant latest papers and their open-source implementations at <https://github.com/fahadshamshad/awesome-transformers-in-medical-imaging>."
  ],
  "key_claims": [
    {
      "claim": "The survey comprehensively reviews applications of Transformers in medical imaging across segmentation, classification, detection, reconstruction, synthesis, registration, clinical report generation, and other tasks.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "The paper claims to be the first survey paper that comprehensively covers applications of Transformers in the medical imaging domain.",
      "evidence_section": "Motivation and Contributions",
      "page": null
    },
    {
      "claim": "The survey provides taxonomies, task-specific challenges, and insights for each medical imaging application area.",
      "evidence_section": "Motivation and Contributions",
      "page": null
    },
    {
      "claim": "The paper highlights that ViT-based architectures have achieved impressive results over benchmark medical datasets, competing with and often improving over CNN-based approaches.",
      "evidence_section": "3.3 Discussion",
      "page": null
    },
    {
      "claim": "The survey states that most proposed ViT-based models are pre-trained on ImageNet for downstream medical image segmentation, but this is sub-optimal due to the large domain gap between natural and medical image modalities.",
      "evidence_section": "3.3 Discussion",
      "page": null
    },
    {
      "claim": "The paper notes that transformer-based approaches have achieved state-of-the-art performance both in terms of Natural Language Generation (NLG) and Clinical Efficacy (CE) metrics for clinical report generation.",
      "evidence_section": "9 CLINICAL REPORT GENERATION",
      "page": null
    },
    {
      "claim": "The survey emphasizes that transformer-based medical image synthesis approaches can generate more realistic images than GAN-based methods.",
      "evidence_section": "7.3 Discussion",
      "page": null
    },
    {
      "claim": "The paper concludes that transformer-based registration is still at early stages and that no firm conclusion can yet be drawn.",
      "evidence_section": "8.1 Discussion",
      "page": null
    }
  ]
