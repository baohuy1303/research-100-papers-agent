  "novel_contributions": [
    "A new large-scale CNN-based foundation model, InternImage, that scales to over 1 billion parameters and 400 million training images.",
    "An improved deformable convolution operator, DCNv3, with shared weights, multi-group aggregation, and softmax-normalized modulation scalars.",
    "Tailored block-level, stacking, and scaling rules that make CNNs extensible to large-scale foundation-model settings.",
    "Strong results on ImageNet, COCO, and ADE20K, including a new record 65.4 box AP on COCO test-dev and 62.9 mIoU on ADE20K."
  ],
  "key_claims": [
    {
      "claim": "InternImage is presented as the first CNN that effectively scales to over 1 billion parameters and 400 million training images while matching or exceeding state-of-the-art ViTs.",
      "evidence_section": "Introduction",
      "page": null
    },
    {
      "claim": "InternImage uses deformable convolution as the core operator and combines it with transformer-like components such as LN, FFN, and GELU to build a CNN-based foundation model.",
      "evidence_section": "3. Proposed Method",
      "page": null
    },
    {
      "claim": "DCNv3 introduces shared weights, multi-group spatial aggregation, and softmax normalization to make deformable convolution more suitable for large-scale training.",
      "evidence_section": "3.1. Deformable Convolution v3",
      "page": null
    },
    {
      "claim": "InternImage-B achieves 84.9% top-1 accuracy on ImageNet-1K, and InternImage-H reaches 89.6% after large-scale pre-training and fine-tuning.",
      "evidence_section": "4.1. Image Classification",
      "page": null
    },
    {
      "claim": "InternImage-H achieves 65.4% box mAP on COCO test-dev and is described as a new record, outperforming prior CNNs and ViTs.",
      "evidence_section": "Abstract",
      "page": null
    },
    {
      "claim": "InternImage-H reaches 62.9 mIoU on ADE20K with Mask2Former, which the paper states is the best result on that benchmark.",
      "evidence_section": "4.3. Semantic Segmentation",
      "page": null
    },
    {
      "claim": "Ablations show that shared weights, multi-group aggregation, and softmax normalization are all important for performance and efficiency.",
      "evidence_section": "4.4. Ablation Study",
      "page": null
    }
  ]
}